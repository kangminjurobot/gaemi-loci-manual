{/*
  Image lightbox using PhotoSwipe.
  - Click any content image to open.
  - Wheel or pinch to zoom in/out further.
  - Drag to pan when zoomed.
  - Esc, outside click, or close button to exit.
  Renders no visible output; ships the client script only.
*/}

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  type PhotoSwipeLightboxInstance = InstanceType<typeof PhotoSwipeLightbox>;
  let lightbox: PhotoSwipeLightboxInstance | null = null;

  function initZoom(): void {
    if (lightbox) return;

    const gallery = document.querySelector('main');
    if (!gallery) return;

    lightbox = new PhotoSwipeLightbox({
      gallery: 'main',
      children: 'img:not([data-zoom-skip])',
      pswpModule: () => import('photoswipe'),
      bgOpacity: 0.9,
      initialZoomLevel: 'fit',
      secondaryZoomLevel: 2,
      maxZoomLevel: 6,
      wheelToZoom: true,
      padding: { top: 24, bottom: 24, left: 24, right: 24 },
      showHideAnimationType: 'zoom',
    });

    // Derive source dimensions from each <img> on the page.
    lightbox.addFilter('itemData', (itemData) => {
      const el = (itemData as { element?: Element }).element;
      if (el instanceof HTMLImageElement) {
        const widthAttr = Number(el.getAttribute('width'));
        const heightAttr = Number(el.getAttribute('height'));
        return {
          ...itemData,
          src: el.currentSrc || el.src,
          width: el.naturalWidth || widthAttr || 1600,
          height: el.naturalHeight || heightAttr || 900,
          alt: el.alt,
          msrc: el.currentSrc || el.src,
          element: el,
        };
      }
      return itemData;
    });

    // Show a zoom-in cursor on matching images.
    gallery
      .querySelectorAll<HTMLImageElement>('img:not([data-zoom-skip])')
      .forEach((img) => {
        img.style.cursor = 'zoom-in';
      });

    lightbox.init();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initZoom);
  } else {
    initZoom();
  }
  window.addEventListener('pageshow', initZoom);
</script>
