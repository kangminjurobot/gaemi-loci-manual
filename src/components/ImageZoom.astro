{/*
  Image zoom initialization. Click any content image to zoom.
  This component renders no visible output; it only ships the client script.
*/}

<script>
  import mediumZoom from 'medium-zoom';

  function initImageZoom() {
    // Content images live inside <main>. Exclude anything explicitly skipped.
    const images = document.querySelectorAll<HTMLImageElement>(
      'main img:not([data-zoom-skip])',
    );
    if (images.length === 0) return;

    // medium-zoom auto-attaches click handlers to matching elements and
    // handles cursor, backdrop, and close interactions for us.
    mediumZoom(images, {
      background: 'rgba(0, 0, 0, 0.85)',
      margin: 24,
      scrollOffset: 0,
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initImageZoom);
  } else {
    initImageZoom();
  }
  // Re-init on bfcache restore (browser back/forward).
  window.addEventListener('pageshow', initImageZoom);
</script>
